<Window x:Class="CrabModManager.CreditsWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Title="Credits"
	Width="380" Height="280" ResizeMode="NoResize"
	WindowStartupLocation="CenterOwner"
	Background="{StaticResource Bg}">
	<Window.Resources>
		<Style TargetType="TextBlock">
			<Setter Property="Foreground" Value="{StaticResource Fg}"/>
		</Style>
		<Style TargetType="Hyperlink">
			<Setter Property="Foreground" Value="{StaticResource Accent}"/>
		</Style>
	</Window.Resources>
	<StackPanel Margin="20" VerticalAlignment="Center">
		<TextBlock Text="Crab Mod Manager" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
		<TextBlock HorizontalAlignment="Center" Margin="0,4,0,16">
			by Bungus (in-game: <Run FontWeight="SemiBold">PerryGoBrrrr</Run>)
		</TextBlock>

		<TextBlock HorizontalAlignment="Center" Margin="0,4">
			<Hyperlink NavigateUri="https://github.com/rinpoche-peregrine/CrabModManager"
				RequestNavigate="OnNavigate">
				github.com/rinpoche-peregrine/CrabModManager
			</Hyperlink>
		</TextBlock>

		<TextBlock HorizontalAlignment="Center" Margin="0,12,0,4" Foreground="{StaticResource FgDim}">
			Support development:
		</TextBlock>
		<TextBlock HorizontalAlignment="Center">
			<Hyperlink NavigateUri="https://ko-fi.com/Z8Z852YLV" RequestNavigate="OnNavigate">
				ko-fi.com/Z8Z852YLV
			</Hyperlink>
		</TextBlock>

		<Button Content="Close" Click="OnClose" Width="80" Margin="0,20,0,0"
			HorizontalAlignment="Center"
			Background="{StaticResource BgPanel}" Foreground="{StaticResource Fg}"
			BorderBrush="{StaticResource Accent}" BorderThickness="1" Padding="10,5"/>
	</StackPanel>
</Window>
